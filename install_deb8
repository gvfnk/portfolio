# copy new deb8 kernel and initrd to /boot partition
cp_deb8_kern()
{
have_boot_mnt=`mount | grep ${raw_ssd}1 | awk '{print $3}'`
if [ "x$have_boot_mnt" = "x" ]
then
echo boot not mounted
fsck -y ${raw_ssd}1
mount ${raw_ssd}1 /mnt/1
fi

# if we have the same boot files as those on flash - remove them from /mnt/1/boot
# we have not much space for multiple boot files!!!
kern_file=`ls -1 /boot | awk '/vmlinuz/ {fname=$1} END {print fname}'`
initrd_file=`ls -1 /boot | awk '/initrd.img/ {fname=$1} END {print fname}'`

if [ -f /mnt/1/boot/${kern_file} ]
then
rm /mnt/1/boot/${kern_file}
fi
if [ -f /mnt/1/boot/${initrd_file} ]
then
rm /mnt/1/boot/${initrd_file}
fi


# if upgrade variant_a then
if [ "x$var_a" = "x1" ]
then
cp ${new_boot_files}/* /mnt/1/ && kern_copied=1 && echo kern_copied=1  >> ${cmd_log}
fi
}
##########################################
# add/change strings in menu.lst to set boot from flash drive with deb8livroot label by default
# or fall back to 0 (first line of menu)
set_deb8_boot()
{
#set -x
cat ${backup_dir}/menu.lst2.default | grep -v -E "^default|^fallback" >${backup_dir}/menu.lst-tmp
# set filenames for kernel and initrd aftre files stored in $new_boot_files
kern_file=`ls -1 ${new_boot_files} | awk '/vmlinuz/ {fname=$1} END {print fname}'`
initrd_file=`ls -1 ${new_boot_files} | awk '/initrd.img/ {fname=$1} END {print fname}'`

# add link to boot new kernel and root from usb flash
cat <<EOC >>  ${backup_dir}/menu.lst-tmp

title deb8
root (hd0,0)
kernel /${kern_file} root=/dev/disk/by-label/${deb8label} rw console=ttyS0,19200 panic=1
initrd /${initrd_file}
boot
EOC

# set default boot
def_title=`cat  ${backup_dir}/menu.lst-tmp | awk ' /^title/ {count=count+1} /^title deb8/ {set_def= count-1} END {print set_def }'`

awk_c="cat  ${backup_dir}/menu.lst2.default | awk ' /^default/ {prev_def=\$2} /^fallback/ {print prev_def, \$2, \$3, \$4}'"
prev_title=`eval $awk_c`

echo default $def_title  > ${backup_dir}/menu.lst-new
echo fallback $prev_title  >>${backup_dir}/menu.lst-new
#echo "# previous_default=$prev_title" >>${backup_dir}/menu.lst-new
echo "" >>${backup_dir}/menu.lst-new
cat ${backup_dir}/menu.lst-tmp  >>${backup_dir}/menu.lst-new

# alternative way to rewrite menu.lst
#eval "cat  ${boot_dir}/grub/menu.lst | grep -v -E "^fallback" | sed -e 's/^default.*$/default $def_title\\nfallback 0\\n/'" >${backup_dir}/menu.lst-new

cp ${backup_dir}/menu.lst-new ${boot_dir}/grub/menu.lst

}
