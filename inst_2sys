mkdir -p ${backup_dir}

# all etc changed
tar czf ${backup_dir}/etc-backup.${cur_date}.tgz /rw/etc /rw2/etc 

# all net dir and misc services
tar czhf ${backup_dir}/etc-network-backup.${cur_date}.tgz /etc/network /etc/ntp.* /etc/hosts /etc/hostname 

#sshd
if [ -d /etc/ssh ]
then
tar czhf ${backup_dir}/etc-ssh-backup.${cur_date}.tgz /etc/ssh
fi

# openvpn
if [ -d /etc/openvpn ]
then
tar czhf ${backup_dir}/etc-ovpn-backup.${cur_date}.tgz /etc/openvpn /etc/default/openvpn
fi

