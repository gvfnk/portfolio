if [ -d /etc/ppp ]
then
tar czhf ${backup_dir}/etc-ppp-backup.${cur_date}.tgz /etc/ppp
fi

# dnsmask & dhcp
if [ -d /etc/dnsmasq.d ]
then
tar czhf ${backup_dir}/etc-dnsmasq-backup.${cur_date}.tgz /etc/dnsmasq.d /etc/dnsmasq.conf
fi

#interfaces
cp /etc/network/interfaces ${backup_dir}/interfaces
cp /etc/resolv.conf ${backup_dir}/resolv.conf
cp /etc/hostname ${backup_dir}/hostname
cp /etc/hosts ${backup_dir}/hosts

#iptables ifplugd
cp /etc/default/iptables  ${backup_dir}/iptables
cp /etc/default/ifplugd  ${backup_dir}/ifplugd

# mac addresses
#ifconfig -a | awk '/Ethernet/ {print $1, $5}' > ${backup_dir}/mactab
#ifconfig -a | awk '/Ethernet/ {print p$1, $5}' > ${backup_dir}/mactab1

# udev way to keep ether name static
#KERNEL=="eth*", SYSFS{address}=="00:12:34:fe:dc:ba", NAME="eth0" >> /etc/udev/rules.d/010_netinterfaces.rules
#ifconfig -a | awk '/Ethernet/ {print "KERNEL==\"eth*\", SYSFS{address}==\""$5"\", NAME=\"" $1"\""}' > ${backup_dir}/70-persistent-net.rules
