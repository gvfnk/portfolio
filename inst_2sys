FSTAB
}
############################################
# returns the system to default state
# if $1 = 1 then also delete ext4 kernel
# 1 - remove ${raw_ssd}4 partition
# 2 - unmount everything
# 3 - restore menu.lst from backup
revert_state()
{
# check if all ssd unmounted
# Need to run twice to be sure, if we did recursive mount
mount | grep -w -E "${raw_ssd}6" | awk '{print $1}' | xargs -I {} umount -f {}
mount | grep -w -E "${raw_ssd}5" | awk '{print $1}' | xargs -I {} umount -f {}

# remove 4th part
echo destroying 4th partition on SSD
#echo -e "d\n4\nw\n" | fdisk ${raw_ssd}
parted -s ${raw_ssd} rm 6 rm 5 rm 4
partprobe ${raw_ssd}

# restore old menu.lst
if [ -f ${boot_dir}/grub/menu.lst2.backup ]
then
cp ${boot_dir}/grub/menu.lst2.backup ${boot_dir}/grub/menu.lst
rm /boot/vmlinuz-3.* /boot/initrd.img-3.* /boot/System.map-3.*
fi

if [ "x$1" = "x1" ]
then
if [ -f ${boot_dir}/grub/menu.lst.backup ]
then
cp ${boot_dir}/grub/menu.lst.backup ${boot_dir}/grub/menu.lst
rm /boot/vmlinuz-2.*ext4
fi # have menu backup
fi # do revert to 1st state - before ext4 kernel installed
exit
}
