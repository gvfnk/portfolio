#!/bin/sh
# set -e # stop on errors
set -x # debug

# if = 1 then full dump restore of old rw2 partition on newly built FS or just network config only (default)
#full_rw2_dump=1

# required size for new install (MB)
required_part_size=1250
new_kern_ver="3.16.7"

# this is dd image of new deb8 system -- !!! -- raw device /dev/sda
deb8wildixnew_img="/root/deb8_my_raw-generated.img"
#deb8wildixnew_img="/root/deb8wildix231215.img"

# partition where main system lays when mounted as a loop dev
deb8_sys_part="p1"
# partition where rw2 lays when mounted as a loop dev
deb8_rw2_part="p5"
# unix_time_sec() - set for version control
cur_date=`date "+%s"`
# SSD device name
raw_ssd="/dev/sda"
# filename to store backup of SSD !!! - raw device
backup_raw_file="/root/backup-sda-raw.img.gz"
# filename to store rw2 partition -- specially not compressed for further work
backup_raw_file_rw="/root/backup-sda3-part.img"

error_log="/root/error.log"
# file log, where will be stored all variables showing the upgrade steps
cmd_log="/root/command.log"
# directory where new kernel and initrd is stored -- these files will be copied to /boot partition
new_boot_files="/root/new_boot"
# FS label which will be set on newly created partition
deb8label=deb8wildix
# read vars from log
#source ./${cmd_log}
# zeroing the log
echo cur_date=${cur_date} > ${cmd_log}
echo  "================ ${cur_date} New start of script $@" >> ${error_log}

##################################################################### subs
# backup current raw FS on flash disk
backup_raw()
{
#if [ "x$raw_backup_done" = "x1" -a -f $backup_raw_file ]
if [ -f $backup_raw_file ]
then
# do not do a lot of backups
raw_backup_done=1
echo we already backuped
else
echo !!! We are going to backup your system disk on flash grive. This process will take about 15-35 minutes depending on your system''s CPU, flash write speed, and so on
echo Please be patient
# store full dd image and compress it
dd if=$raw_ssd bs=4M conv=notrunc | gzip > ${backup_raw_file} && echo raw_backup_done=1 >> $cmd_log && raw_backup_done=1
# store rw (sda3) image for further work (uncompressed)
dd if=${raw_ssd}3 bs=4M conv=notrunc of=${backup_raw_file_rw} && echo raw_backup3_done=1 >> $cmd_log && raw_backup3_done=1
fi

if [ "x$raw_backup_done" = "x1" -a -f $backup_raw_file ]
then
echo Backup process succeeded!!
else
echo Something goes wrong!! Cant do raw backup!!
echo Something goes wrong!! Cant do raw backup!! >> ${error_log}
exit 1
fi
}
##############################
# mount boot partition and compare its size with new kernel and initrd image
chk_boot()
{
# TODO: if mount unsuccessful run fsck on this dev
mount ${raw_ssd}1 /mnt/1
boot_part_free_size_k=`df -k /mnt/1 | awk '/dev/ {print $4}' `
new_kern_size_k=`du -sk /mnt/1/*${new_kern_ver}* | awk '{sum=sum+$1} END {print sum}'`
new_boot_size_k=`du -sk ${new_boot_files} | awk '{print $1}'`
boot_free_all=`expr $boot_part_free_size_k + $new_kern_size_k + 12`
if [ $boot_free_all -lt $new_boot_size_k ]
then
echo small_boot=1 >> $cmd_log
echo Boot partition size is too small to for new kernel
echo We have $boot_free_all kbytes but need $new_boot_size kbytes
echo Cant install new system along with old one. The new system will overwrite the old one.
echo var_b=1 >> $cmd_log
export var_b=1
else
echo var_a1=1 >> $cmd_log
export var_a1=1
fi
umount /mnt/1
}

#################################
# check 3 conditions for var_a install
# 1. Boot size is OK to store new kernel and initrd
# 2. partitions less then 4
# 3. SSD size bigger then requiered

chk_free_ssd()
{
# number of partitions
parts_cnt=`fdisk -l ${raw_ssd} | grep -E "^${raw_ssd}" | wc -l`
if [ $parts_cnt -gt 3 ]
then
echo var_b=1 >> $cmd_log
export var_b=1
echo You have $parts_cnt partitions on your SSD, which is more then 3,
echo Cant install new system along with old one. The new system will overwrite the old one.
echo var_b=1 >> $cmd_log
export var_b=1
else # partitions less then 4, its OK for var "a" install
echo var_a2=1 >> $cmd_log
export var_a2=1

# check free space on SSD
free_ssd_m=`parted ${raw_ssd} unit B print free | awk '/Free Space/ {print int($3/1024/1024)}' | tail -n 1` && echo free_ssd_m=$free_ssd_m >> ${cmd_log}
if [ $free_ssd_m -lt $required_part_size ]
then
echo You have $free_ssd_m MBytes free on SSD which is smaller then required $required_part_size MBytes,
echo Cant install new system along with old one. The new system will overwrite the old one.
echo var_b=1 >> $cmd_log
export var_b=1
else # ssd space is enough
echo var_a3=1 >> $cmd_log
export var_a3=1
if [ "x$var_a1" = "x1" ]
then
echo All requierements for Var A OK
echo var_a=1 >> $cmd_log
export var_a=1
fi # var_a1
fi # free_ssd_m

fi # parts_cnt

}
####################################
# Create 4th partition and ext4 FS on it labeled 'deb8wildix'
# then mount it on /mnt/4

create_new_part()
{
# creating new part with fdisk requieres unmounting everything on this device
# echo -e  "n\np\n\n\nw\nq\n" | fdisk ${raw_ssd} && part4_created=1 && echo part4_created=1 >> ${cmd_log}

# create new with parted
# starting point of new  part
start_mb=`parted -s ${raw_ssd} unit MB print free | awk '/Free Space/ {print $1}' | tail -n 1`
if [ "$start_mb" = "0.00MB" ]
then
echo no free space on device ${raw_ssd}
echo no free space on device ${raw_ssd} >> ${error_log}
exit 1
fi
parted -s ${raw_ssd} mkpart primary ext4 ${start_mb} 100%
partprobe ${raw_ssd}
mkfs.ext4 -L ${deb8label} -q -F ${raw_ssd}4 && fs4_created=1 && echo fs4_created=1 >> ${cmd_log}
mount ${raw_ssd}4 /mnt/4 && part4_mounted=1 && echo part4_mounted=1 >> ${cmd_log}

is_mnt_pnt=`mount | grep -w "/mnt/4"`
if [ -z "${is_mnt_pnt}" ]
then
echo ${raw_ssd}4 file system not mounted
echo ${raw_ssd}4 file system not mounted >> ${error_log}
exit 1 
fi

# last check the size of newly created partition
real_size_m=`df -m /mnt/4 | awk '/dev/ {print $4}'`

if [ $real_size_m -lt $required_part_size ]
then
echo You have $real_size_m MBytes free on ${raw_ssd}4 partition of SSD which is smaller then required $required_part_size MBytes,
echo Cant install new system along with old one. The new system will overwrite the old one.
echo var_b=1 >> $cmd_log
export var_b=1
else # ssd space is enough
echo var_a4=1 >> $cmd_log
export var_a4=1
fi # real_size

}
#########################################
# copy new deb8 system to newly created partition
#
dumprestore_sys_fs()
{
# unmount and destroy loop if they were created
umount /mnt/deb8
losetup -d /dev/loop0

if [ -f ${deb8wildixnew_img} ]
then
losetup /dev/loop0 ${deb8wildixnew_img}
partprobe /dev/loop0
mkdir -p /mnt/deb8
mount /dev/loop0${deb8_sys_part} /mnt/deb8 && deb8_mount=1 && echo deb8_mount=1  >> ${cmd_log}
else
echo Live image FS for deb8 = ${deb8wildixnew_img} not found
echo Live image FS for deb8 = ${deb8wildixnew_img} not found >> ${error_log}
exit 1
fi # deb8 image \not found

if [ "x${deb8_mount}" = "x1" ]
then

# check if this a mount point or not
is_mnt_pnt=`mount | grep -w "/mnt/4"`
if [ -z "${is_mnt_pnt}" ]
then
echo ${raw_ssd}4 file system not mounted
echo ${raw_ssd}4 file system not mounted >> ${error_log}
exit 1 
fi # new part 4 mounted

# go to dir where new ssd part mounted
cd /mnt/4
dump -0 -f - /dev/loop0${deb8_sys_part} | restore -r -f - && restore_sys=1 && echo restore_sys=1  >> ${cmd_log}
umount /dev/loop0${deb8_sys_part}
else
echo Error in mounting deb8 sys partition ${deb8wildixnew_img} ==== /dev/loop0${deb8_sys_part}
echo Error in mounting deb8 sys partition ${deb8wildixnew_img} ==== /dev/loop0${deb8_sys_part} >> ${error_log}
exit 1
fi # mount success

}
