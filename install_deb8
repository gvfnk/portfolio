############################################
# returns the system to default state
# 1 - remove /dev/sda4 partition
# 2 - unmount everything
# 3 - restore rw2 partition from backuped image if it is
restore_def()
{
backup_dir=/root/backup
# check if all ssd unmounted
# Need to run twice to be sure, if we did recursive mount
mount | grep -w -E "${raw_ssd}." | awk '{print $1}' | xargs -I {} umount -f {}
mount | grep -w -E "${raw_ssd}." | awk '{print $1}' | xargs -I {} umount -f {}

# remove 4th part
echo destroying 4th partition on SSD
#echo -e "d\n4\nw\n" | fdisk ${raw_ssd}
parted -s ${raw_ssd} rm 4
partprobe ${raw_ssd}

# restore old menu.lst
if [ -f ${backup_dir}/menu.lst2.default ]
then
mount ${raw_ssd}1 /mnt/1
cp ${backup_dir}/menu.lst2.default /mnt/1/grub/menu.lst
fi

# unmount and destroy loop if they were created
# check if all loop unmounted 
# Need to run twice to be sure, if we did recursive mount
mount | grep -w -E "/dev/loop.*" | awk '{print $1}' | xargs -I {} umount -f {}
mount | grep -w -E "/dev/loop.*" | awk '{print $1}' | xargs -I {} umount -f {}
losetup -d /dev/loop0
losetup -d /dev/loop1

# restore rw2 partition
if [ -f ${backup_raw_file_rw} ]
then
dd if=${backup_raw_file_rw} of=${raw_ssd}3 bs=4M conv=notrunc && restored_rw2=1 && echo restored_rw2=1  >> ${cmd_log}
else
echo  ${backup_raw_file_rw} not found
echo  ${backup_raw_file_rw} not found >> ${error_log}
exit 1
fi
}
############################################
# dump\restore rw2 partition contents to newly created\dd-ed part from backuped image
# 1 - dest_dir where new rw2 partition is mounted
