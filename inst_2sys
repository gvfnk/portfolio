############################################################################### sub definition
#########################################################################################################################
# find /boot partition and mount it
# check its free size for further decision
# set vars $have_boot_dev $mounted_b $boot_sz $small_boot
mount_boot()
{
#set -x 
have_boot_dev=`cat /etc/fstab | awk ' /\/boot/ {print $1}'`
if [ -z "$have_boot_dev" ]
then
echo !!!!!!!  no /boot in /etc/fstab set by default "${raw_ssd}1 /boot"
boot_mnt_param="${raw_ssd}1 /boot"
fi

mounted_b=`mount | awk '/\/boot/ {print $3}'`

if [ -z "$mounted_b" ]
then
# mount boot slice on /boot (usually /dev/hda1 )
if [ -n $boot_mnt_param ]
then
mount -o rw ${raw_ssd}1 /boot || (echo cant mount /boot, you may try to run fsck; exit 1 )
else
mount -o rw /boot || (echo cant mount /boot, you may try to run fsck; exit 1)
fi # boot_mnt_param
else
# remount rw in case it was mounted ro
boot_dir=$mounted_b
mount -o remount,rw $boot_dir
fi
}
##########################################
install_deb5_kernel_ext4()
{
# $1 - dest dir
dest_dir=$1

# Do this unless we already have these files in /boot
have_kern=`ls -1 ${dest_dir} | awk '/vmlinuz-2.6.*-ext4/ {fname=$1} END {print fname}'`
if [ -z "$have_kern" ]
then
echo We are going to download and untar new kernel
echo make sure you have network access
echo Press Enter if ready or ctrl-C to  stop
read ans

if curl --output /dev/null --silent --head --fail "${deb5_kern_uri}"; then
eval "curl -o - ${deb5_kern_uri} | tar xz -C ${dest_dir} -f -"
else
echo Can not install kernel with ext4
  echo "URL does not exist: ${deb5_kern_uri}"
exit 1
fi

else # we have kernel
echo You already have kernel with ext4 support
fi
}
##########################################
# add/change strings in menu.lst to set boot from flash drive with deb8livroot label by default
# or fall back to 0 (first line of menu)
set_ext4_boot()
{

# do changes unless we already have the menu item booting new kernel with -ext4 suffix

have_ext4_item=`grep -E "vmlinuz-2.6.*-ext4" ${boot_dir}/grub/menu.lst`

if [ -z "$have_ext4_item" ]
then
kern_file=`ls -1 ${boot_dir} | awk '/vmlinuz-2.6.*-ext4/ {fname=$1} END {print fname}'`

cat ${boot_dir}/grub/menu.lst | grep -v -E "^default|^fallback" > ${boot_dir}/grub/menu.lst-new
if [ -f "${boot_dir}/grub/menu.lst.backup" ]
then
echo You already have menu backup
else
cp  ${boot_dir}/grub/menu.lst  ${boot_dir}/grub/menu.lst.backup
fi
# add new menu item
cat <<EOC >>  ${boot_dir}/grub/menu.lst-new

title  ${kern_file} ext4 enabled
root    (hd0,0)
kernel    /${kern_file} root=${raw_ssd}2 ro console=ttyS0,19200 panic=1
savedefault
boot
EOC

# set default boot
def_title=`cat  ${boot_dir}/grub/menu.lst-new | awk ' /^title/ {count=count+1} /^title .*ext4 enabled/ {set_def= count-1} END {print set_def }'`
prev_title=0

echo default $def_title  >  ${boot_dir}/grub/menu.lst
echo fallback $prev_title  >> ${boot_dir}/grub/menu.lst

#echo serial --unit=0 --speed=19200  >> ${boot_dir}/grub/menu.lst
#echo terminal --timeout=5 serial console >> ${boot_dir}/grub/menu.lst
echo "" >> ${boot_dir}/grub/menu.lst
cat  ${boot_dir}/grub/menu.lst-new  >> ${boot_dir}/grub/menu.lst
rm  ${boot_dir}/grub/menu.lst-new

echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
echo "!!!!!!!!!                  You should reboot NOW to check the new kernel"
echo "!!!!!!!!!           Do NOT run this script again until reboot"
echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
exit
else
echo We already have ext4 enabled kernel in boot menu
#echo You may delete old kernel (not ext4 enabled)
# TODO: ask and delete old files and menu item
fi # have ext4 item
}
#########################################
#  compare boot part size with new kernel and initrd image
chk_boot_size()
{

boot_part_free_size_k=`df -k /boot | awk '/dev/ {print $4}' `

# TODO get new deb8 kernel size
#new_boot_size_k=`du -sk ${new_boot_files} | awk '{print $1}'`
# set the new kern size by hands
new_boot_size_k=10000
# check if we already have this kern files in /boot (in case of multiple run of this script)
new_kern_size_k=`du -sk /boot/*${new_kern_ver}* 2>/dev/null | awk '{sum=sum+$1} END {print sum}'`
# add the space occupied by this files since we overwrite them without additional space allocation
boot_free_all=`expr $boot_part_free_size_k + $new_kern_size_k + 12`
if [ $boot_free_all -lt $new_boot_size_k ]
then
echo Boot partition size is too small to for new kernel
echo We have $boot_free_all kbytes but need $new_boot_size kbytes
echo Cant install new system along with old one. The new system will overwrite the old one.
exit 1
fi
}
