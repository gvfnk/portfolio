{
new_deb8_mnt=$1
# restore rw2 partition
if [ -f ${backup_raw_file_rw} ]
then
mkdir -p /mnt/deb5rw2
losetup /dev/loop1 ${backup_raw_file_rw} && loop1_set_rw2=1 && echo  loop1_set_rw2=1 >> ${cmd_log}
mount /dev/loop1 /mnt/deb5rw2
#cd $new_deb8_mnt

if [ "x$loop1_set_rw2" = "x1" ]
then
#dump -0 -f - /dev/loop1 | restore -r -f - && dumprw2_ok=1 && echo  dumprw2_ok=1 >> ${cmd_log}
cp -a /mnt/deb5rw2  ${new_deb8_mnt}
fi # loop1 set success
else
echo  ${backup_raw_file_rw} not found rw2_dump
echo  ${backup_raw_file_rw} not found rw2_dump >> ${error_log}
exit 1
fi
}
