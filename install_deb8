###########################################
# var_b install -- if SSD size not enough for new partition creation
# check if backup exists and ask a question
# dd new image to raw device
# mount root ( to /mnt/deb8 ) and rw2 ( to /mnt/deb8/rw2 ) partitions for config restoring
dd_new_fs()
{

if [ ! -f $backup_raw_file ]
then
echo "Backup image not found. Are you sure you want to copy new image to SSD? (yes/N)"
read ans
if [ "x$ans" != "xyes" ]
then
exit 1
fi # I'm sure
fi # no backup

# check if all ssd unmounted
mount | grep -w -E "${raw_ssd}." | awk '{print $1}' | xargs -I {} umount -f {}

# check if all loop unmounted
mount | grep -w -E "/dev/loop.*" | awk '{print $1}' | xargs -I {} umount -f {}

echo !!!!!!!!!  We are going to dd new SSD image !!!!! 
echo !!!!!!!!!  We are going to dd new SSD image !!!!!  >> ${error_log}

echo Do NOT power off your system, otherise you will need console cable to change boot source to flash drive!!!

