##########################################
# check 3 conditions for var_a install
# 1. Boot size is OK to store new kernel and initrd
# 2. partitions less then 4
# 3. SSD size bigger then requiered
chk_free_ssd()
{
# number of partitions
parts_cnt=`fdisk -l ${raw_ssd} | grep -E "^${raw_ssd}" | wc -l`
if [ $parts_cnt -gt 3 ]
then
echo You have $parts_cnt partitions on your SSD, which is more then 3,
echo Cant install new system along with old one. The new system will overwrite the old one.
exit 1
else # partitions less then 4, its OK for var "a" install
echo Its Ok, we have less the 4 partitions on the disk.

# check free space on SSD
free_ssd_m=`parted ${raw_ssd} unit B print free | awk '/Free Space/ {print int($3/1024/1024)}' | tail -n 1` && echo free_ssd_m=$free_ssd_m
if [ $free_ssd_m -lt $required_part_size ]
then
echo You have $free_ssd_m MBytes free on SSD which is smaller then required $required_part_size MBytes,
echo Cant install new system along with old one. The new system will overwrite the old one.
exit 1
else # ssd space is enough
echo We have enough space on disk for the new system
fi # free_ssd_m
fi # parts_cnt
}
#####################################
# Create 4th partition and ext4 FS on it labeled 'deb8wildix'
# then mount it on /mnt/4
create_new_part()
{
#$1 - new mount point

deb8_mnt=$1

# create new with parted
# starting point of new  part
start_mb=`parted -s ${raw_ssd} unit MB print free | awk '/Free Space/ {print $1}' | tail -n 1`
end_mb=`parted -s ${raw_ssd} unit MB print free | awk -v ns=${new_system_size_mb} '/Free Space/ {print $1+ns"M"}' | tail -n 1`
if [ "$start_mb" = "0.00MB" ]
then
echo no free space on device ${raw_ssd}
echo no free space on device ${raw_ssd} >> ${error_log}
exit 1
fi

extended_part_end=`echo " "| awk -vstart=$start_mb  -vext_size=$required_part_size '{print ( start + ext_size) }' `
# create new ext partition and two logical ones inside, size of system part is set on start of this script in ${new_system_size_mb} variable
parted -s ${raw_ssd} mkpart ext ${start_mb} ${extended_part_end}MB
partprobe ${raw_ssd}

parted -s ${raw_ssd} mkpartfs logic ext2  ${start_mb} ${end_mb}MB
parted -s ${raw_ssd} mkpartfs logic ext2 ${end_mb} ${extended_part_end}MB

# wait some time
count=0
until [ -b ${raw_ssd}6 -a -b ${raw_ssd}5 -o "$count" = "5" ]
do
count=`expr $count + 1`
partprobe ${raw_ssd}
done

parted -s ${raw_ssd} print free

mkfs.ext4 -L ${deb8label} -q -FF ${raw_ssd}5 || exit 1
mkfs.ext4 -L ${deb8labelrw2} -q -FF ${raw_ssd}6 || exit 1

mkdir -p ${deb8_mnt}
mount ${raw_ssd}5 ${deb8_mnt} || ( echo system part not  mounted; exit 1)
mkdir -p ${deb8_mnt}/rw2
mount ${raw_ssd}6 ${deb8_mnt}/rw2 || ( echo rw2 part not mounted; exit 1)

is_mnt_pnt=`mount | grep -w "${raw_ssd}5"`
is_mnt_pnt2=`mount | grep -w "${raw_ssd}6"`
# last check!
if [ -z "${is_mnt_pnt}" ]
then
echo ${deb8_mnt} file system not mounted
exit 1.
fi
if [ -z "${is_mnt_pnt2}" ]
then
echo ${deb8_mnt}/rw2 file system not mounted
exit 1.
fi
}
